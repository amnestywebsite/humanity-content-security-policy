{
  "name": "amnestywebsite/humanity-content-security-policy",
  "type": "project",
  "license": "none",
  "minimum-stability": "stable",
  "require-dev": {
    "bigbite/phpcs-config": "^2.0.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "lint": "./vendor/bin/phpcs .",
		"lang": ["@makePot", "@updatePoMo"],
		"makePot": "@wp i18n make-pot . ./languages/aicsp.pot --domain=aicsp --exclude=src,vendor",
		"updatePoMo": [
			"@wp i18n update-po ./languages/aicsp.pot",
			"@wp i18n make-mo ./languages",
			"@wp i18n make-php ./languages",
			"@wp i18n make-json ./languages --no-purge"
		]
  },
  "scripts-descriptions": {
    "lint": "Runs PHP coding standard checks",
    "lang": "runs makePot and updatePoMo",
    "makePot": "Updates the POT file",
    "updatePoMo": "Updates the PO files from the POT file; compiles to MO, JSON (JED), PHP"
  }
}
